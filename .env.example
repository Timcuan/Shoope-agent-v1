# 🚀 Shopee Intelligence Engine - Environment Configuration
# Salin file ini ke .env dan isi nilai yang sesuai untuk deployment.

# --- CORE CONFIGURATION ---
APP_ENV=production
DATABASE_URL=sqlite:///./data/shopee_agent.db
ARCHIVE_DIR=./data/archive
API_SECRET_KEY=  # Generate a long random string for internal API security

# --- TELEGRAM BOT CONFIGURATION ---
TELEGRAM_BOT_TOKEN=  # Dapatkan dari @BotFather
ADMIN_CHAT_ID=       # ID Chat Telegram Anda untuk notifikasi admin (P0/P1)
TELEGRAM_ALLOWED_USER_IDS=  # Pisahkan dengan koma (contoh: 12345,67890)

# --- SHOPEE API CONFIGURATION ---
# Dapatkan di https://open.shopee.com/
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# --- AI & LLM CONFIGURATION ---
LLM_PROVIDER=gemini  # Pilihan: gemini, openrouter, disabled
LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=      # Dapatkan di https://aistudio.google.com/
OPENROUTER_API_KEY=  # Opsional jika menggunakan OpenRouter

# --- LOGISTICS & PRINTING (Optional) ---
# Dapatkan di https://www.printnode.com/
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=

# --- GOOGLE CLOUD INTEGRATION (Optional - for GSheets Audit) ---
# Isi dengan path ke file JSON service account atau konten JSON-nya
GOOGLE_SERVICE_ACCOUNT=
GOOGLE_ADMIN_EMAIL=

# --- NETWORKING (Optional) ---
HTTP_PROXY_URL=  # Isi jika server Anda memerlukan proxy untuk akses Shopee/LLM
